generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  USER
  ARTISAN
  EXPOSANT
  ADMIN
}

enum ArticlePosition {
  UNE            // J1-3: Front page
  FACE_UNE       // J4-6: Second page
  PAGES_4_5      // J7-8
  PAGES_6_7      // J9-10
  PAGES_8_9      // J11-12
  PAGES_10_11    // J13-16
  PAGES_12_13    // J17-21
  ARCHIVES       // J22+
}

enum ArticleCategory {
  ACTUALITE
  CULTURE
  CINEMA
  MUSIQUE
  SPORT
  DIASPORA
  BUSINESS
  LIFESTYLE
  OPINION
}

enum InscriptionStatus {
  PENDING
  VALIDATED
  REJECTED
}

// Legacy enum kept for reference — tier is now a free String on Ticket
// Allows custom tiers like PROMO_100, JOUR1_DAHOMEY, etc.
enum TicketTier {
  EARLY_BIRD
  STANDARD
  VIP
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}


enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExhibitorPack {
  ENTREPRENEUR_1J
  ENTREPRENEUR
  RESTAURATION
  SAISON
}

enum BookingStatus {
  PENDING
  PARTIAL
  CONFIRMED
  CANCELLED
}


// ─── AUTH MODELS ─────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           Role      @default(USER)
  bio            String?
  country        String?
  phone          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  articles    Article[]
  products    Product[]
  orders      Order[]
  tickets     Ticket[]
  favorites   Favorite[]
  officielContents OfficielContent[]
  exhibitorBookings ExhibitorBooking[]
  exhibitorProfiles ExhibitorProfile[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── JOURNAL (L'AFROPÉEN) ───────────────────────────────

model Article {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  excerpt     String
  content     String          @db.Text
  coverImage     String?
  altText        String?
  gradientClass  String?
  category       ArticleCategory
  tags           String[]        @default([])
  position       ArticlePosition @default(UNE)
  publishedAt    DateTime        @default(now())
  dayCount       Int             @default(1)
  featured       Boolean         @default(false)
  isSponsored    Boolean         @default(false)
  sponsorName    String?
  readingTimeMin Int?
  status         ArticleStatus   @default(PUBLISHED)
  views          Int             @default(0)
  source         String          @default("manual")
  sourceUrl      String?
  authorType     String          @default("humain")

  // SEO
  metaTitle       String?
  metaDescription String?
  seoKeywords     String[]        @default([])

  // Réseaux sociaux
  socialTwitter   String?
  socialInstagram String?
  socialLinkedin  String?
  socialFacebook  String?
  socialTiktok    String?

  authorId    String
  eventId     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  author       User          @relation(fields: [authorId], references: [id])
  event        Event?        @relation(fields: [eventId], references: [id])
  socialPosts  SocialPost[]
  socialDrafts SocialDraft[]

  @@index([slug])
  @@index([status])
  @@index([position])
  @@index([category])
  @@index([publishedAt])
  @@index([eventId])
}

// ─── EVENTS + TICKETING ─────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  coverImage  String?
  venue       String
  address     String
  venues      Json?      // [{name, address}] — multi-venue support
  date        DateTime
  endDate     DateTime?
  capacity     Int
  showCapacity Boolean  @default(true)
  program      Json?
  tiers        Json?
  priceEarly   Float
  priceStd    Float
  priceVip    Float
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets      Ticket[]
  reservations EventReservation[]
  articles     Article[]

  @@index([date])
}

model Ticket {
  id              String     @id @default(cuid())
  eventId         String
  userId          String
  tier            String
  price           Float
  qrCode          String?
  stripeSessionId String?
  purchasedAt     DateTime   @default(now())
  checkedInAt     DateTime?

  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  visitDate       DateTime?

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

// ─── MARKETPLACE ────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  price       Float
  images      String[] // array of URLs
  category    String
  country     String
  stock       Int      @default(0)
  published   Boolean  @default(true)
  artisanId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  artisan    User        @relation(fields: [artisanId], references: [id])
  orderItems OrderItem[]
  favorites  Favorite[]

  @@index([category])
  @@index([country])
  @@index([price])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  total           Float
  stripeSessionId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ─── L'OFFICIEL D'AFRIQUE — INSCRIPTIONS ────────────────

model Inscription {
  id          String   @id @default(cuid())
  entreprise  String
  categorie   String
  directeur   String
  adresse     String?
  ville       String
  codePostal  String?
  pays        String
  mobile      String
  telephone   String?
  email       String
  siteWeb     String?
  facebook    String?
  instagram   String?
  tiktok      String?
  whatsapp    String?
  youtube     String?
  linkedin    String?
  description String            @db.Text
  motsCles    String?
  newsletter  Boolean           @default(false)
  status      InscriptionStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([email])
  @@index([categorie])
  @@index([status])
}

// ─── L'OFFICIEL D'AFRIQUE — CONTENU ÉDITORIAL ────────────

model OfficielContent {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  type       String   // "article", "interview", "portrait", "guide"
  content    String   @db.Text
  excerpt    String?
  coverImage String?
  category   String
  published  Boolean  @default(false)
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([type])
  @@index([category])
  @@index([published])
}

// ─── ANNUAIRE / DIRECTORY ────────────────────────────────

model DirectoryEntry {
  id            String   @id @default(cuid())
  companyName   String?
  contactName   String
  category      String   // Exposant, Artiste, Mannequin, Média, etc.
  city          String?
  country       String?
  phone         String?
  email         String?
  website       String?
  facebook      String?
  instagram     String?
  tiktok        String?
  whatsapp      String?
  linkedin      String?
  youtube       String?
  description   String   @db.Text
  event         String?  // Événement intéressé
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([country])
  @@index([published])
}

// ─── COMMENTS (AVIS PUBLICS) ──────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  name      String
  email     String
  rating    Int      // 1–5
  message   String   @db.Text
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─── RSS AUTOMATION ─────────────────────────────────────

enum DetectedArticleStatus {
  PENDING     // Detected, not yet scored
  SCORED      // Scored by AI
  REWRITING   // Being rewritten
  REWRITTEN   // Rewritten, awaiting publication
  PUBLISHED   // Published to journal
  IGNORED     // Score too low or manually ignored
  ERROR       // Processing error
}

model RssFeed {
  id             String   @id @default(cuid())
  name           String
  url            String   @unique
  website        String?
  category       String   @default("ACTUALITE")
  language       String   @default("fr")
  region         String?
  reliability    Int      @default(5)
  active         Boolean  @default(true)
  lastFetchedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  detectedArticles DetectedArticle[]

  @@index([active])
}

model DetectedArticle {
  id              String                 @id @default(cuid())
  title           String
  sourceUrl       String                 @unique
  summary         String?                @db.Text
  sourceCategory  String?
  sourceName      String?
  sourceImageUrl  String?
  sourcePubDate   DateTime?
  score           Int?
  scoreReason     String?
  rewrittenTitle  String?
  rewrittenContent String?               @db.Text
  rewrittenExcerpt String?
  rewrittenMeta   String?
  rewrittenKeywords String[]             @default([])
  status          DetectedArticleStatus  @default(PENDING)
  publishedArticleId String?
  errorMessage    String?
  feedId          String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  feed RssFeed @relation(fields: [feedId], references: [id])

  @@index([status])
  @@index([feedId])
  @@index([createdAt])
}

// ─── NEWSLETTER ─────────────────────────────────────────

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())
}

// ─── RÉSERVATIONS GRATUITES ─────────────────────────────

model EventReservation {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  firstName   String
  lastName    String
  email       String
  phone       String
  guests      Int      @default(1)
  status      String   @default("CONFIRMED") // CONFIRMED | CANCELLED
  checkedInAt DateTime?
  createdAt   DateTime @default(now())

  @@index([eventId])
  @@index([email])
}

// ─── PROSPECTS EXPOSANTS ──────────────────────────────

model ExposantLead {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  brand       String
  sector      String
  phone       String
  email       String
  eventName   String
  // Suivi
  status      String   @default("SENT")  // SENT, DEPOSIT_PAID, QUOTED, CONFIRMED, CANCELLED
  depositPaidAt DateTime?
  bookingId   String?  // lien vers ExhibitorBooking après paiement
  stripeSessionId String?
  remindedAt  DateTime? // date de relance 24h
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// ─── BILLETTERIE EXPOSANTS ─────────────────────────────

model ExhibitorBooking {
  id                   String         @id @default(cuid())
  userId               String
  user                 User           @relation(fields: [userId], references: [id])

  // Infos exposant
  companyName          String
  contactName          String
  email                String
  phone                String
  sector               String

  // Réservation
  pack                 ExhibitorPack
  events               String[]       // ["foire-afrique", "juste-une-danse", ...]
  totalDays            Int
  stands               Int            @default(1)
  totalPrice           Float

  // Paiement fractionné
  installments         Int            @default(1)  // 1 à 5
  installmentAmount    Float
  paidInstallments     Int            @default(0)

  // Stripe
  stripeSessionId      String?
  stripeSubscriptionId String?

  // Facture
  invoiceNumber        String?        @unique

  // Statut
  status               BookingStatus  @default(PENDING)

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  profile  ExhibitorProfile?
  payments ExhibitorPayment[]

  @@index([userId])
  @@index([status])
}

model ExhibitorPayment {
  id        String   @id @default(cuid())
  bookingId String
  booking   ExhibitorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount    Float
  type      String   // "deposit" | "installment" | "early_payment" | "full_payment"
  label     String   // e.g. "Acompte", "Mensualité 3/9", "Paiement anticipé (2 mois)"
  stripeId  String?  // Stripe session or invoice ID
  paidAt    DateTime @default(now())

  @@index([bookingId])
}

// ─── PROFIL VISIBILITÉ EXPOSANT ─────────────────────────

model ExhibitorProfile {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  booking       ExhibitorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  // Token unique pour le formulaire public
  token         String   @unique @default(cuid())

  // Infos exposant
  companyName   String?
  sector        String?
  firstName     String?
  lastName      String?
  phone         String?
  email         String?

  // Réseaux sociaux
  facebook      String?
  instagram     String?
  twitter       String?
  linkedin      String?
  tiktok        String?

  // Description
  description   String?  @db.Text

  // Médias (URLs Bunny CDN)
  logoUrl       String?
  image1Url     String?
  image2Url     String?
  image3Url     String?
  videoUrl      String?

  // Options
  masterclass   Boolean  @default(false)
  daysPresent   String[] // ["1er-mai", "2-mai"]

  // Statut
  submittedAt   DateTime?
  promoStatus   String   @default("PENDING") // PENDING, SCHEDULED, POSTED

  publications  ExhibitorPublication[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([token])
  @@index([bookingId])
}

model ExhibitorPublication {
  id          String    @id @default(cuid())
  profileId   String
  profile     ExhibitorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  platform    String    // facebook, instagram, twitter, linkedin, tiktok, lafropeen, officiel
  status      String    @default("PENDING") // PENDING, SCHEDULED, POSTED
  postUrl     String?
  postedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@unique([profileId, platform])
  @@index([profileId])
}

// ─── MESSAGES DE CONTACT ──────────────────────────────

model ContactMessage {
  id         String   @id @default(cuid())
  category   String   // EXPOSANT, MANNEQUIN, PRESTATAIRE, PARTENAIRE, INSTITUTION, MEDIA, ARTISTE
  firstName  String
  lastName   String
  email      String
  phone      String?
  company    String?
  message    String   @db.Text
  read       Boolean  @default(false)
  status     String   @default("NOUVEAU") // NOUVEAU, CONTACTE, INTERESSE, ACOMPTE, CONFIRME, PERDU
  notes      String?  @db.Text
  draftReply String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  replies    ContactReply[]

  @@index([category])
  @@index([read])
  @@index([status])
  @@index([createdAt])
}

model ContactReply {
  id        String   @id @default(cuid())
  messageId String
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  sentBy    String   // admin user id
  sentAt    DateTime @default(now())

  @@index([messageId])
}

// ─── LEADS (Facebook Ads) ────────────────────────────────

model Lead {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  source     String   // facebook_leads, manual, etc.
  profile    String   @default("Visiteur") // Visiteur, Exposant, Artiste, Média, Autre
  formId     String?
  fbLeadId   String?  @unique
  converted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([source])
  @@index([converted])
  @@index([createdAt])
}

// ─── PUBLICATIONS RÉSEAUX SOCIAUX ────────────────────────

enum SocialPlatform {
  TWITTER
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  TIKTOK
}

enum SocialPostStatus {
  PENDING
  POSTED
  FAILED
}

model SocialPost {
  id          String           @id @default(cuid())
  articleId   String
  platform    SocialPlatform
  status      SocialPostStatus @default(PENDING)
  postId      String?          // ID renvoyé par la plateforme
  postUrl     String?          // URL du post publié
  content     String           @db.Text
  hashtags    String[]         @default([])
  imageUrl    String?
  errorMessage String?
  postedAt    DateTime?
  createdAt   DateTime         @default(now())

  article Article @relation(fields: [articleId], references: [id])

  @@index([articleId])
  @@index([platform])
  @@index([status])
}

// ─── SOCIAL DRAFTS (BROUILLONS ENGAGEMENT) ──────────────

enum SocialDraftType {
  COMMENT       // Commentaire sur un post existant
  REPLY         // Réponse à un commentaire
  PROMO         // Post promotionnel autonome (L'Officiel, Marketplace, etc.)
  ENGAGEMENT    // Like + commentaire d'engagement
}

enum SocialDraftStatus {
  DRAFT         // Brouillon généré par IA
  APPROVED      // Validé par l'admin
  REJECTED      // Rejeté par l'admin
  POSTED        // Publié sur la plateforme
  FAILED        // Échec de publication
}

model SocialDraft {
  id            String            @id @default(cuid())
  platform      SocialPlatform
  type          SocialDraftType   @default(COMMENT)
  status        SocialDraftStatus @default(DRAFT)
  content       String            @db.Text
  editedContent String?           @db.Text    // Contenu modifié par l'admin
  imageUrl      String?
  targetPostId  String?           // ID du post social cible (pour commentaire/reply)
  targetPostUrl String?           // URL du post social cible
  articleId     String?           // Article lié (optionnel)
  section       String?           // "lafropeen", "officiel", "marketplace", "saison-culturelle"
  postId        String?           // ID renvoyé après publication
  postUrl       String?           // URL du commentaire publié
  reviewedBy    String?           // Admin qui a validé
  reviewedAt    DateTime?
  postedAt      DateTime?
  errorMessage  String?
  scheduledFor  DateTime?         // Publication programmée
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  article       Article?          @relation(fields: [articleId], references: [id])

  @@index([status])
  @@index([platform])
  @@index([type])
  @@index([section])
  @@index([createdAt])
}

// ─── WHATSAPP MESSAGES ──────────────────────────────

model WhatsAppMessage {
  id             String   @id @default(cuid())
  waMessageId    String   @unique // WhatsApp message ID (wamid.xxx)
  from           String   // sender phone number
  to             String   // receiver phone number
  contactName    String   @default("Inconnu")
  direction      String   // "inbound" or "outbound"
  type           String   @default("text") // text, image, button, etc.
  body           String?  @db.Text
  mediaUrl       String?
  status         String?  // sent, delivered, read (for outbound)
  read           Boolean  @default(false)
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([from])
  @@index([direction])
  @@index([read])
  @@index([createdAt])
  @@index([archived])
}

// ─── EMAIL INBOX ──────────────────────────────────────

model Email {
  id             String   @id @default(cuid())
  messageId      String   @unique
  imapUid        Int?
  folder         String   @default("INBOX")
  fromName       String?
  fromEmail      String
  toEmails       String[]
  ccEmails       String[] @default([])
  subject        String
  bodyText       String?  @db.Text
  bodyHtml       String?  @db.Text
  snippet        String?
  hasAttachments Boolean  @default(false)
  attachments    Json?
  inReplyTo      String?
  references     String[] @default([])
  isRead         Boolean  @default(false)
  isArchived     Boolean  @default(false)
  isStarred      Boolean  @default(false)
  label          String?
  receivedAt     DateTime
  syncedAt       DateTime @default(now())

  @@index([isArchived, isRead])
  @@index([fromEmail])
  @@index([receivedAt])
  @@index([inReplyTo])
  @@index([label])
}

model EmailSyncState {
  id         String   @id @default(cuid())
  folder     String   @unique
  lastUid    Int      @default(0)
  lastSyncAt DateTime @default(now())
}

model SocialCredential {
  id           String         @id @default(cuid())
  platform     SocialPlatform @unique
  accessToken  String         @db.Text
  refreshToken String?        @db.Text
  expiresAt    DateTime?
  memberId     String?        // LinkedIn member ID, etc.
  metadata     Json?          // Extra platform-specific data
  updatedAt    DateTime       @updatedAt
  createdAt    DateTime       @default(now())
}

// ─── SONDAGE EXPOSANTS ──────────────────────────────────

enum SurveyAnswer {
  YES
  NO
}

model ExhibitorSurvey {
  id        String       @id @default(cuid())
  email     String
  name      String
  phone     String?
  answer    SurveyAnswer
  days      Int[]        // [1], [2], or [1, 2]
  comment   String?
  sentAt    DateTime?    // date d'envoi de la proposition WhatsApp
  createdAt DateTime     @default(now())

  @@unique([email])
}

// ─── SOUMISSIONS FORMULAIRE EXPOSANTS (données brutes) ──────

model ExhibitorFormEntry {
  id              String   @id @default(cuid())
  submittedAt     DateTime?
  societe         String
  firstName       String?
  lastName        String?
  phone           String?
  email           String?
  description     String?  @db.Text
  secteur         String?
  besoinPrise     Boolean  @default(false)
  instagram       String?
  facebook        String?
  visibilite      String?  // "Interview avec notre journaliste", etc.
  masterclass     Boolean  @default(false)
  joursPresence   String[] @default([])
  salon           String   @default("Foire Afrique 2024")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([secteur])
  @@index([salon])
}
