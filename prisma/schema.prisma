generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BehaviorScore {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  score       Int      @default(0)
  signals     Json     @default("{}")
  flagged     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fingerprint])
  @@index([flagged])
}

model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model PendingCheckout {
  id               String   @id @default(cuid())
  email            String
  eventId          String
  tier             String
  stripeSessionId  String?
  createdAt        DateTime @default(now())
  expiresAt        DateTime

  @@unique([email, eventId, tier])
  @@index([expiresAt])
  @@index([stripeSessionId])
}

model User {
  id                     String             @id @default(cuid())
  name                   String?
  email                  String             @unique
  emailVerified          DateTime?
  image                  String?
  password               String?
  role                   Role               @default(USER)
  bio                    String?
  country                String?
  phone                  String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  totpEnabled            Boolean            @default(false)
  totpSecret             String?
  parrainCode            String?            @unique
  qrToken                String?            @unique
  soldeBonus             Float              @default(0)
  soldeNtbc              Float              @default(0)
  tier                   NtbcTier           @default(SEMENCE)
  accounts               Account[]
  articles               Article[]
  exhibitorBookings      ExhibitorBooking[]
  exhibitorProfiles      ExhibitorProfile[]
  favorites              Favorite[]
  avisEmis               NtbcAvis[]
  parrainagesRecus       NtbcParrainage[]   @relation("filleul")
  parrainagesEmis        NtbcParrainage[]   @relation("parrain")
  ntbcTransactionsEmises NtbcTransaction[]  @relation("ntbc_emetteur")
  ntbcTransactionsRecues NtbcTransaction[]  @relation("ntbc_receveur")
  officielContents       OfficielContent[]
  orders                 Order[]
  products               Product[]
  sessions               Session[]
  tickets                Ticket[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Article {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  excerpt         String
  content         String
  coverImage      String?
  gradientClass   String?
  category        ArticleCategory
  position        ArticlePosition @default(UNE)
  publishedAt     DateTime        @default(now())
  dayCount        Int             @default(1)
  featured        Boolean         @default(false)
  isSponsored     Boolean         @default(false)
  sponsorName     String?
  readingTimeMin  Int?
  status          ArticleStatus   @default(PUBLISHED)
  views           Int             @default(0)
  authorId        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  altText         String?
  metaDescription String?
  metaTitle       String?
  socialFacebook  String?
  socialInstagram String?
  socialLinkedin  String?
  socialTiktok    String?
  socialTwitter   String?
  source          String          @default("manual")
  tags            String[]        @default([])
  authorType      String          @default("humain")
  sourceUrl       String?
  seoKeywords     String[]        @default([])
  eventId         String?
  author          User            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  event           Event?          @relation(fields: [eventId], references: [id])
  socialDrafts    SocialDraft[]
  socialPosts     SocialPost[]

  @@index([slug])
  @@index([status])
  @@index([position])
  @@index([category])
  @@index([publishedAt])
  @@index([eventId])
}

model Event {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  description      String
  coverImage       String?
  venue            String
  address          String
  date             DateTime
  endDate          DateTime?
  capacity         Int
  showCapacity     Boolean            @default(true)
  program          Json?
  tiers            Json?
  priceEarly       Decimal            @db.Decimal(10, 2)
  priceStd         Decimal            @db.Decimal(10, 2)
  priceVip         Decimal            @db.Decimal(10, 2)
  published        Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  venues           Json?
  articles         Article[]
  reservations     EventReservation[]
  ntbcTransactions NtbcTransaction[]
  tickets          Ticket[]

  @@index([date])
}

model Ticket {
  id                String           @id @default(cuid())
  eventId           String
  userId            String
  price             Decimal          @db.Decimal(10, 2)
  qrCode            String?
  stripeSessionId   String?
  purchasedAt       DateTime         @default(now())
  tier              String
  checkedInAt       DateTime?
  email             String?
  firstName         String?
  lastName          String?
  phone             String?
  visitDate         DateTime?
  installments      Int              @default(1)
  totalPaid         Decimal          @default(0) @db.Decimal(10, 2)
  qrNonce           String?
  qrRevokedAt       DateTime?
  transferCount     Int              @default(0)
  lastTransferredAt DateTime?
  event             Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: SetNull)
  payments          TicketPayment[]
  transfers         TicketTransfer[]

  @@index([eventId])
  @@index([userId])
}

model TicketTransfer {
  id              String         @id @default(cuid())
  ticketId        String
  ticket          Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromUserId      String
  fromEmail       String
  fromFirstName   String?
  fromLastName    String?
  toEmail         String?
  toFirstName     String?
  toLastName      String?
  toUserId        String?
  toPhone         String?
  status          TransferStatus @default(PENDING)
  mode            TransferMode
  invitationHash  String         @unique
  amount          Decimal?       @db.Decimal(10, 2)
  publicPrice     Decimal?       @db.Decimal(10, 2)
  stripeSessionId String?
  stripeRefundId  String?
  message         String?
  createdAt       DateTime       @default(now())
  expiresAt       DateTime
  acceptedAt      DateTime?
  cancelledAt     DateTime?
  listedAt        DateTime?

  @@index([ticketId])
  @@index([toEmail, status])
  @@index([expiresAt])
  @@index([status])
  @@index([status, listedAt])
}

model TicketPayment {
  id       String   @id @default(cuid())
  ticketId String
  amount   Decimal  @db.Decimal(10, 2)
  type     String
  label    String
  stripeId String?
  paidAt   DateTime @default(now())
  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, stripeId, type])
  @@index([ticketId])
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  price       Decimal     @db.Decimal(10, 2)
  images      String[]
  category    String
  country     String
  stock       Int         @default(0)
  published   Boolean     @default(true)
  artisanId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  favorites   Favorite[]
  orderItems  OrderItem[]
  artisan     User        @relation(fields: [artisanId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([country])
  @@index([price])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  total           Decimal     @db.Decimal(10, 2)
  stripeSessionId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Inscription {
  id          String            @id @default(cuid())
  entreprise  String
  categorie   String
  directeur   String
  adresse     String?
  ville       String
  codePostal  String?
  pays        String
  mobile      String
  telephone   String?
  email       String
  siteWeb     String?
  facebook    String?
  instagram   String?
  tiktok      String?
  whatsapp    String?
  youtube     String?
  linkedin    String?
  description String
  motsCles    String?
  newsletter  Boolean           @default(false)
  status      InscriptionStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([email])
  @@index([categorie])
  @@index([status])
}

model OfficielContent {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  type       String
  content    String
  excerpt    String?
  coverImage String?
  category   String
  published  Boolean  @default(false)
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([category])
  @@index([published])
}

model DirectoryEntry {
  id          String   @id @default(cuid())
  companyName String?
  contactName String
  category    String
  city        String?
  country     String?
  phone       String?
  email       String?
  website     String?
  facebook    String?
  instagram   String?
  tiktok      String?
  whatsapp    String?
  linkedin    String?
  youtube     String?
  description String
  event       String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logoUrl     String?

  @@index([category])
  @@index([country])
  @@index([published])
}

model ModelApplication {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String
  height       String?
  measurements String?
  experience   String?
  instagram    String?
  bookUrl      String?
  photo1Url    String?
  photo2Url    String?
  photo3Url    String?
  event        String?
  status       String   @default("PENDING")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([event])
}

model ArtistApplication {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String
  discipline  String
  groupName   String?
  country     String?
  description String?
  videoUrl    String?
  instagram   String?
  facebook    String?
  website     String?
  event       String?
  status      String   @default("PENDING")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([discipline])
}

model Comment {
  id        String   @id @default(cuid())
  name      String
  email     String
  rating    Int
  message   String
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model RssFeed {
  id               String            @id @default(cuid())
  name             String
  url              String            @unique
  website          String?
  category         String            @default("ACTUALITE")
  language         String            @default("fr")
  region           String?
  reliability      Int               @default(5)
  active           Boolean           @default(true)
  lastFetchedAt    DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  detectedArticles DetectedArticle[]

  @@index([active])
}

model DetectedArticle {
  id                 String                @id @default(cuid())
  title              String
  sourceUrl          String                @unique
  summary            String?
  sourceCategory     String?
  sourceName         String?
  sourceImageUrl     String?
  sourcePubDate      DateTime?
  score              Int?
  scoreReason        String?
  rewrittenTitle     String?
  rewrittenContent   String?
  rewrittenExcerpt   String?
  rewrittenMeta      String?
  rewrittenKeywords  String[]              @default([])
  status             DetectedArticleStatus @default(PENDING)
  publishedArticleId String?
  errorMessage       String?
  feedId             String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  feed               RssFeed               @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([feedId])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  isActive        Boolean   @default(true)
  subscribedAt    DateTime  @default(now())
  emailVerified   Boolean   @default(false)
  verifyExpiresAt DateTime?
  verifyToken     String?   @unique
}

model NewsletterCampaign {
  id          String    @id @default(cuid())
  subject     String
  htmlContent String
  status      String    @default("PENDING")
  totalEmails Int       @default(0)
  sentEmails  Int       @default(0)
  lastSentAt  DateTime?
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model EventReservation {
  id          String    @id @default(cuid())
  eventId     String
  firstName   String
  lastName    String
  email       String
  phone       String
  guests      Int       @default(1)
  status      String    @default("CONFIRMED")
  createdAt   DateTime  @default(now())
  checkedInAt DateTime?
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([email])
}

model ExposantLead {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  brand           String
  sector          String
  phone           String
  email           String
  eventName       String
  status          String    @default("SENT")
  depositPaidAt   DateTime?
  bookingId       String?
  stripeSessionId String?
  remindedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model ExhibitorBooking {
  id                   String             @id @default(cuid())
  userId               String
  companyName          String
  contactName          String
  email                String
  phone                String
  sector               String
  pack                 ExhibitorPack
  events               String[]
  totalDays            Int
  totalPrice           Decimal            @db.Decimal(10, 2)
  installments         Int                @default(1)
  installmentAmount    Decimal            @db.Decimal(10, 2)
  paidInstallments     Int                @default(0)
  stripeSessionId      String?
  stripeSubscriptionId String?
  status               BookingStatus      @default(PENDING)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  stands               Int                @default(1)
  invoiceNumber        String?            @unique
  standNumber          Int?
  user                 User               @relation(fields: [userId], references: [id], onDelete: SetNull)
  payments             ExhibitorPayment[]
  profile              ExhibitorProfile?

  @@index([userId])
  @@index([status])
  @@index([email])
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    @default("FREE_STAND")
  value     Decimal   @default(0) @db.Decimal(10, 2)
  label     String
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  usedBy    String?
  bookingId String?
  expiresAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([code])
  @@index([active])
}

model StandBlock {
  id          String   @id @default(cuid())
  eventId     String
  standNumber Int
  reason      String?
  createdAt   DateTime @default(now())

  @@unique([eventId, standNumber])
  @@index([eventId])
}

model ExhibitorPayment {
  id        String           @id @default(cuid())
  bookingId String
  amount    Decimal          @db.Decimal(10, 2)
  type      String
  label     String
  stripeId  String?
  paidAt    DateTime         @default(now())
  booking   ExhibitorBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model ExhibitorProfile {
  id             String                 @id @default(cuid())
  bookingId      String                 @unique
  userId         String?
  token          String                 @unique @default(cuid())
  companyName    String?
  sector         String?
  firstName      String?
  lastName       String?
  phone          String?
  email          String?
  facebook       String?
  instagram      String?
  description    String?
  logoUrl        String?
  image1Url      String?
  image2Url      String?
  image3Url      String?
  videoUrl       String?
  masterclass    Boolean                @default(false)
  daysPresent    String[]
  submittedAt    DateTime?
  promoStatus    String                 @default("PENDING")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  linkedin       String?
  tiktok         String?
  twitter        String?
  website        String?
  tokenExpiresAt DateTime?
  booking        ExhibitorBooking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user           User?                  @relation(fields: [userId], references: [id])
  publications   ExhibitorPublication[]

  @@index([token])
  @@index([bookingId])
}

model ExhibitorPublication {
  id        String           @id @default(cuid())
  profileId String
  platform  String
  status    String           @default("PENDING")
  postUrl   String?
  postedAt  DateTime?
  createdAt DateTime         @default(now())
  profile   ExhibitorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, platform])
  @@index([profileId])
}

model ContactMessage {
  id         String         @id @default(cuid())
  category   String
  firstName  String
  lastName   String
  email      String
  phone      String?
  company    String?
  message    String
  read       Boolean        @default(false)
  createdAt  DateTime       @default(now())
  notes      String?
  status     String         @default("NOUVEAU")
  updatedAt  DateTime       @default(now()) @updatedAt
  draftReply String?
  replies    ContactReply[]

  @@index([category])
  @@index([read])
  @@index([status])
  @@index([createdAt])
}

model ContactReply {
  id        String         @id @default(cuid())
  messageId String
  body      String
  sentBy    String
  sentAt    DateTime       @default(now())
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model MediaAccreditation {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  outlet    String
  type      String   @default("PRESSE")
  event     String?
  status    String   @default("PENDING")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  source    String
  profile   String   @default("Visiteur")
  formId    String?
  fbLeadId  String?  @unique
  converted Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([source])
  @@index([converted])
  @@index([createdAt])
}

model SocialPost {
  id           String           @id @default(cuid())
  articleId    String
  platform     SocialPlatform
  status       SocialPostStatus @default(PENDING)
  postId       String?
  postUrl      String?
  content      String
  hashtags     String[]         @default([])
  imageUrl     String?
  errorMessage String?
  postedAt     DateTime?
  createdAt    DateTime         @default(now())
  article      Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([platform])
  @@index([status])
}

model SocialDraft {
  id            String            @id @default(cuid())
  platform      SocialPlatform
  type          SocialDraftType   @default(COMMENT)
  status        SocialDraftStatus @default(DRAFT)
  content       String
  editedContent String?
  imageUrl      String?
  targetPostId  String?
  targetPostUrl String?
  articleId     String?
  section       String?
  postId        String?
  postUrl       String?
  reviewedBy    String?
  reviewedAt    DateTime?
  postedAt      DateTime?
  errorMessage  String?
  scheduledFor  DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  article       Article?          @relation(fields: [articleId], references: [id])

  @@index([status])
  @@index([platform])
  @@index([type])
  @@index([section])
  @@index([createdAt])
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  waMessageId String   @unique
  from        String
  to          String
  contactName String   @default("Inconnu")
  direction   String
  type        String   @default("text")
  body        String?
  mediaUrl    String?
  status      String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  archived    Boolean  @default(false)

  @@index([from])
  @@index([direction])
  @@index([read])
  @@index([createdAt])
  @@index([archived])
}

model Email {
  id             String   @id @default(cuid())
  messageId      String   @unique
  imapUid        Int?
  folder         String   @default("INBOX")
  fromName       String?
  fromEmail      String
  toEmails       String[]
  ccEmails       String[] @default([])
  subject        String
  bodyText       String?
  bodyHtml       String?
  snippet        String?
  hasAttachments Boolean  @default(false)
  attachments    Json?
  inReplyTo      String?
  references     String[] @default([])
  isRead         Boolean  @default(false)
  isArchived     Boolean  @default(false)
  isStarred      Boolean  @default(false)
  receivedAt     DateTime
  syncedAt       DateTime @default(now())
  label          String?

  @@index([isArchived, isRead])
  @@index([fromEmail])
  @@index([receivedAt])
  @@index([inReplyTo])
  @@index([label])
}

model EmailSyncState {
  id         String   @id @default(cuid())
  folder     String   @unique
  lastUid    Int      @default(0)
  lastSyncAt DateTime @default(now())
}

model SocialCredential {
  id                    String         @id @default(cuid())
  platform              SocialPlatform @unique
  accessToken           String
  refreshToken          String?
  expiresAt             DateTime?
  memberId              String?
  metadata              Json?
  updatedAt             DateTime       @updatedAt
  createdAt             DateTime       @default(now())
  encryptedAccessToken  String?
  encryptedRefreshToken String?
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  action    String
  target    String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RateLimitEntry {
  id        String   @id
  count     Int      @default(1)
  resetAt   DateTime
  createdAt DateTime @default(now())

  @@index([resetAt])
}

model ExhibitorSurvey {
  id        String       @id @default(cuid())
  email     String       @unique
  name      String
  phone     String?
  answer    SurveyAnswer
  days      Int[]
  comment   String?
  sentAt    DateTime?
  createdAt DateTime     @default(now())
}

model ExhibitorFormEntry {
  id            String    @id @default(cuid())
  submittedAt   DateTime?
  societe       String
  firstName     String?
  lastName      String?
  phone         String?
  email         String?
  description   String?
  secteur       String?
  besoinPrise   Boolean   @default(false)
  instagram     String?
  facebook      String?
  visibilite    String?
  salon         String    @default("Foire Afrique 2024")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  joursPresence String[]  @default([])
  masterclass   Boolean   @default(false)

  @@index([email])
  @@index([secteur])
  @@index([salon])
}

model NtbcTransaction {
  id             String   @id @default(cuid())
  emetteurId     String
  receveurId     String
  montantNtbc    Float
  commissionNtbc Float
  netNtbc        Float
  label          String?
  eventId        String?
  createdAt      DateTime @default(now())
  emetteur       User     @relation("ntbc_emetteur", fields: [emetteurId], references: [id])
  event          Event?   @relation(fields: [eventId], references: [id])
  receveur       User     @relation("ntbc_receveur", fields: [receveurId], references: [id])

  @@index([emetteurId])
  @@index([receveurId])
}

model NtbcParrainage {
  id        String   @id @default(cuid())
  parrainId String
  filleulId String
  bonusNtbc Float    @default(4)
  createdAt DateTime @default(now())
  filleul   User     @relation("filleul", fields: [filleulId], references: [id])
  parrain   User     @relation("parrain", fields: [parrainId], references: [id])

  @@unique([parrainId, filleulId])
}

model NtbcAvis {
  id          String   @id @default(cuid())
  userId      String
  eventId     String
  exposantId  String
  note        Int
  commentaire String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, eventId, exposantId])
  @@index([exposantId])
}

